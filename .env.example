# Copy to .env for local development. In Railway, set these as project
# environment variables (Settings -> Variables) instead of committing a file.

PORT=3000

# Comma-separated list of allowed origins for CORS (the deployed app's URL).
# Leave unset to allow all origins during local development.
ALLOWED_ORIGIN=

# Same Supabase project as the app's EXPO_PUBLIC_SUPABASE_URL/ANON_KEY.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Service-role key — Settings -> API in Supabase. Full admin access, bypasses
# RLS entirely. NEVER prefix this with EXPO_PUBLIC_ (or any client-bundle
# convention) and never commit a real value. Only set in Railway's secret
# environment variables. Not used by any route yet (foundation only).
SUPABASE_SERVICE_ROLE_KEY=
