# Copy to .dev.vars for local `wrangler dev` (dotenv-format, gitignored).
# In production, set these with `wrangler secret put <NAME>` instead —
# never commit real values, especially SUPABASE_SERVICE_ROLE_KEY.

# Comma-separated list of allowed origins for CORS (the deployed app's URL).
# Leave unset to allow all origins during local development.
ALLOWED_ORIGIN=

# Same Supabase project as the app's EXPO_PUBLIC_SUPABASE_URL/ANON_KEY.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Service-role key — Settings -> API in Supabase. Full admin access, bypasses
# RLS entirely. Only used locally for testing; in production this must be a
# `wrangler secret put SUPABASE_SERVICE_ROLE_KEY`, never a plain var. Used by
# the employee invite route to call the Supabase Admin API.
SUPABASE_SERVICE_ROLE_KEY=

# Local dev frontend URL (e.g. wherever `expo start --web` serves on this
# machine) — used as `redirectTo` for employee invite emails locally. In
# production this is a plain [vars] entry in wrangler.toml instead, since
# it's not sensitive.
PUBLIC_APP_URL=http://localhost:19006

# Resend API key (resend.com) — sends the "you've been invited to join
# <org>" notification email when an ALREADY-registered user is invited into
# a second organization (backend/src/lib/email.ts). New-account invites
# still go through Supabase Auth's own inviteUserByEmail(), unaffected.
# Requires a Resend account with a verified sending domain. In production
# this must be a `wrangler secret put RESEND_API_KEY`, never a plain var.
RESEND_API_KEY=

# Must be on the domain verified with Resend above. In production this is a
# plain [vars] entry in wrangler.toml instead, since it's not sensitive.
EMAIL_FROM_ADDRESS=Business OS <notifications@localhost.test>
